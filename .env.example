APP_ENV=development
ENABLE_LOGGING=true

# Firebase Web
FIREBASE_API_KEY_WEB=your_firebase_web_api_key
FIREBASE_APP_ID_WEB=your_firebase_web_app_id
FIREBASE_MESSAGING_SENDER_ID_WEB=your_firebase_web_messaging_sender_id
FIREBASE_PROJECT_ID_WEB=synchabit-cyber-os

# Firebase Android
FIREBASE_API_KEY_ANDROID=your_firebase_android_api_key
FIREBASE_APP_ID_ANDROID=your_firebase_android_app_id
FIREBASE_MESSAGING_SENDER_ID_ANDROID=your_firebase_android_messaging_sender_id
FIREBASE_PROJECT_ID_ANDROID=synchabit-4cfa4
FIREBASE_STORAGE_BUCKET_ANDROID=synchabit-4cfa4.firebasestorage.app

# Firebase iOS
FIREBASE_API_KEY_IOS=your_firebase_ios_api_key
FIREBASE_APP_ID_IOS=your_firebase_ios_app_id
FIREBASE_MESSAGING_SENDER_ID_IOS=your_firebase_ios_messaging_sender_id
FIREBASE_PROJECT_ID_IOS=synchabit-4cfa4
FIREBASE_STORAGE_BUCKET_IOS=synchabit-4cfa4.firebasestorage.app
FIREBASE_IOS_BUNDLE_ID=com.synchabit.synchabit

# Firebase macOS
FIREBASE_API_KEY_MACOS=your_firebase_macos_api_key
FIREBASE_APP_ID_MACOS=your_firebase_macos_app_id
FIREBASE_MESSAGING_SENDER_ID_MACOS=your_firebase_macos_messaging_sender_id
FIREBASE_PROJECT_ID_MACOS=synchabit-cyber-os
FIREBASE_STORAGE_BUCKET_MACOS=synchabit-cyber-os.appspot.com
FIREBASE_MACOS_BUNDLE_ID=com.synchabit.app

# RevenueCat API Keys
REVENUECAT_API_KEY_ANDROID_DEV=your_revenuecat_android_dev_key
REVENUECAT_API_KEY_IOS_DEV=your_revenuecat_ios_dev_key

REVENUECAT_API_KEY_ANDROID_STAGING=your_revenuecat_android_staging_key
REVENUECAT_API_KEY_IOS_STAGING=your_revenuecat_ios_staging_key

REVENUECAT_API_KEY_ANDROID_PROD=your_revenuecat_android_prod_key
REVENUECAT_API_KEY_IOS_PROD=your_revenuecat_ios_prod_key

# Supabase Keys
SUPABASE_ANON_KEY_DEV=your_supabase_dev_anon_key
SUPABASE_ANON_KEY_STAGING=your_supabase_staging_anon_key
SUPABASE_ANON_KEY_PROD=your_supabase_prod_anon_key

# AI Engine API Key
AI_ENGINE_API_KEY=your_ai_engine_api_key
